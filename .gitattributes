# Force LF on text files so Windows checkouts don't introduce CRLF, which
# breaks shell scripts and Procfiles on Linux (Railway) with confusing
# "No such file or directory" errors.
* text=auto eol=lf
*.py   text eol=lf
*.sh   text eol=lf
Procfile text eol=lf
*.md   text eol=lf

# Binary
*.db   binary
*.xlsx binary
*.docx binary
*.png  binary
*.jpg  binary
